            try \{\
                const response = await callGemini("A constituent tries to buy the toy.", "You are the Premier. Refuse to sell the toy directly, instead pivot to why the buyer should support building Highway 413 or how the economy is 'open for business'. Be very folksy and evasive. Max 1 sentence.");\
                speech.innerText = response;\
                speech.style.display = 'block';\
                weeble.classList.add('wobble');\
                await speakText(response);\
                setTimeout(() => \{ weeble.classList.remove('wobble'); speech.style.display = 'none'; \}, 5000);\
            \} catch (e) \{ showMessage("ServiceOntario is currently closed for a Stag and Doe."); \}\
            finally \{ purchaseBtn.disabled = false; purchaseSpinner.style.display = 'none'; \}\
        \});\
