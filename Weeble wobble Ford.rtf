                const response = await callGemini(`A reporter asks: "$\{q\}"`, `You are a satirical caricature of an Ontario politician from Etobicoke, born in 1964. Tone: LOUD, gravelly, nasally, aggressive, and defensive. You sound like you're at a loud press conference. Start with "Folks" or "My Friends". Use "at the end of the day", "I'll tell ya right now", and "Ontario is open for business". Pivot to highways, homes, or "gettin' it done". Drop the "g" at the end of words. Sound out of breath. Max 2 sentences.`);\
                speech.innerText = response;\
                speech.style.display = 'block';\
                weeble.classList.add('wobble');\
                await speakText(response);\
                setTimeout(() => \{ weeble.classList.remove('wobble'); speech.style.display = 'none'; \}, 6000);\
            \} catch (e) \{ showMessage("API Error."); \}\
            finally \{ askBtn.disabled = false; loadingSpinner.style.display = 'none'; userQuestion.value = ""; \}\
        \});\
