        excuseBtn.addEventListener('click', async () => \{\
            excuseBtn.disabled = true;\
            excuseSpinner.classList.remove('hidden');\
            try \{\
                const scandals = ["Greenbelt land swap", "Stag and Doe party", "Moving Science Centre", "ServiceOntario in Staples", "Wine in convenience stores", "Highway 413 through the greenbelt", "Secret mandate letters"];\
                const scandal = scandals[Math.floor(Math.random() * scandals.length)];\
                const excuse = await callGemini(`Defend "$\{scandal\}"`, `You are a satirical version of an older politician from Etobicoke. Sound husky, nasally, and defensive. Use "Folks", "Open for business", and "Gettin' it done". Sound slightly out of breath. Max two sentences.`);\
                showMessage(excuse);\
                speakText(excuse);\
            \} finally \{ excuseBtn.disabled = false; excuseSpinner.classList.add('hidden'); \}\
        \});\
\
        function showMessage(text) \{ messageText.innerText = text; messageBox.style.display = 'block'; \}\
        function closeMessage() \{ messageBox.style.display = 'none'; \}\
    </script>\
